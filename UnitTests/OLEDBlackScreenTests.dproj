        <VerInfo_Locale>1035</VerInfo_Locale>
        <Manifest_File>(None)</Manifest_File>
        <AppDPIAwarenessMode>none</AppDPIAwarenessMode>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="..\Source\Units\OBSUnit.Types.pas"/>
        <DCCReference Include="..\Source\Units\OBSUnit.Utils.pas"/>
        <DCCReference Include="Tests.OBSUnit.Utils.pas"/>
